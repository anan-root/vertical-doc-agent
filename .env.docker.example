# Docker 一键部署配置示例。
# 使用方式：复制为 .env.docker，并填写 API_KEY 等敏感配置。

# 大模型接口配置。
API_KEY=
BASE_URL=https://api.deepseek.com
MODEL=deepseek-v4-flash
LLM_PROVIDER=deepseek
API_TYPE=chat_completions
TEMPERATURE=0
TOP_P=1
MAX_TOKENS=
TIMEOUT_SECONDS=180
MAX_RETRIES=2
MAX_WORKERS=8
LLM_TASK_PROFILES_PATH=configs/llm-task-profiles.json
STRUCTURED_OUTPUT_TYPE=json_object
ENABLE_THINKING=false
REASONING_EFFORT=none
STORE_RESPONSE=false

# Web 访问端口与公开地址。
APP_PORT=80
BACKEND_PORT=8000
APP_PUBLIC_URL=http://localhost

# PostgreSQL。
POSTGRES_DB=construction_bidding_agent
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# Redis 目前用于后续异步任务预留。
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# OnlyOffice。
ONLYOFFICE_PORT=8082
ONLYOFFICE_PUBLIC_URL=http://localhost/onlyoffice
ONLYOFFICE_JWT_ENABLED=false
ONLYOFFICE_JWT_SECRET=

# 后端应用。
APP_ENV=docker
APP_STORAGE_ROOT=/app/data
APP_MIGRATIONS_DIR=/app/migrations
APP_SECRET_KEY=change-me
AUTH_REQUIRED=true
DEFAULT_ADMIN_PASSWORD=change-this-admin-password
