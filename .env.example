# OpenAI 兼容接口配置，支持 Responses API 与 Chat Completions API。
# 切换模型平台时，通常只需要修改 API_KEY、BASE_URL、MODEL、API_TYPE。
API_KEY=
BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MODEL=qwen3.6-flash

# 服务商标签，用于报告展示和缓存键。示例：deepseek、dashscope、openai_compatible。
LLM_PROVIDER=dashscope
# 可选值：responses、chat_completions；chat 可作为 chat_completions 的简写。
API_TYPE=responses

# 全局默认生成与运行参数。
# 具体任务可在 LLM_TASK_PROFILES_PATH 指向的 JSON 文件中覆盖这些默认值。
TEMPERATURE=0
TOP_P=1
MAX_TOKENS=
TIMEOUT_SECONDS=180
MAX_RETRIES=2
# 全局默认 LLM 并发数；具体阶段可在 configs/llm-task-profiles.json 中覆盖。
MAX_WORKERS=1
LLM_TASK_PROFILES_PATH=configs/llm-task-profiles.json

# 结构化输出类型。Responses API 会映射为 text.format；Chat Completions 会映射为 response_format。
STRUCTURED_OUTPUT_TYPE=json_object

# 思考/推理模式。当前 qwen3.6-flash 抽取任务默认关闭思考模式。
ENABLE_THINKING=false
REASONING_EFFORT=none
STORE_RESPONSE=false

APP_ENV=local
DATA_DIR=data
OUTPUT_DIR=outputs

# 后端应用配置。
# PostgreSQL 为一期正式数据库方案，不保留 SQLite 兼容层。
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/construction_bidding_agent
APP_STORAGE_ROOT=data
APP_MIGRATIONS_DIR=migrations
APP_SECRET_KEY=change-me
AUTH_REQUIRED=true
DEFAULT_ADMIN_PASSWORD=Admin@123456
